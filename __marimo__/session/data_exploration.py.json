          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"2-taxon-level-statistics\">2. Taxon-level Statistics</h2>\n<span class=\"paragraph\">Two key properties of ecological count data:</span>\n<ul>\n<li><strong>Skewness</strong> \u2014 most taxa have right-skewed distributions (many zeros, few large values)</li>\n<li><strong>Sparsity</strong> \u2014 proportion of segments where each taxon is absent</li>\n</ul></span>"
          }
        }
      ],
      "console": []
    },
